generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  PLANEACION
  EN_CURSO
  SUSPENDIDA
  CERRADA
}

enum EstimateStatus {
  BORRADOR
  ENVIADA
  AUTORIZADA
  PAGADA
}

model Project {
  id             String        @id @default(cuid())
  clienteId      String
  code           String
  name           String
  clientName     String // cliente final de la obra (no confundir con el tenant)
  type           String? // catálogo TIPO_PROYECTO
  contractAmount Decimal       @db.Decimal(14, 2)
  advanceAmount  Decimal       @default(0) @db.Decimal(14, 2) // anticipo recibido
  retentionPct   Decimal       @default(0) @db.Decimal(5, 2) // fondo de garantía %
  startDate      DateTime
  endDate        DateTime?
  status         ProjectStatus @default(PLANEACION)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime? // soft delete (patrón existente)

  budgetItems BudgetItem[]
  costs       Cost[]
  timeEntries TimeEntry[]
  estimates   Estimate[]
  assignments ProjectAssignment[]
  elements    Element[]

  @@unique([clienteId, code])
  @@index([clienteId, status])
}

model BudgetItem {
  id        String       @id @default(cuid())
  projectId String
  parentId  String? // jerarquía: partida → subpartida → concepto
  code      String // "1.2.3"
  name      String
  unit      String? // m3, ton, pza, jornal
  qty       Decimal?     @db.Decimal(14, 4) // null en partidas y en líneas calculadas (isCalculated)
  unitPrice Decimal?     @db.Decimal(14, 4) // null en partidas y en líneas calculadas (isCalculated)
  amount    Decimal      @db.Decimal(14, 2) // partida: Σ hijos (derivado, no se guarda la suma real — ver getPresupuestoProyecto). Línea: qty × unitPrice, o Σ Element.totalCost si isCalculated
  accountId String? // catálogo real de cuentas (Fase 6). null en partidas (nodo padre); obligatorio en líneas
  isCalculated Boolean   @default(false) // true = "2.1 Materia prima": amount viene de Σ Element.totalCost, no se captura (regla #14)
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent      BudgetItem?  @relation("BudgetTree", fields: [parentId], references: [id])
  children    BudgetItem[] @relation("BudgetTree")
  account     CostAccount? @relation(fields: [accountId], references: [id])
  costs       Cost[]
  timeEntries TimeEntry[]
  elements    Element[]

  @@unique([projectId, code])
  @@index([projectId, accountId])
}

// Catálogo real de cuentas (Fase 6, reemplaza el enum CostCategory).
// `level` NO es profundidad de árbol: es el número de grupo contable al que
// pertenece la cuenta (2=Costos operativos, 3=Gastos administrativos,
// 4=Publicidad y marketing, 5=Impuestos) — tanto el nodo de grupo ("2") como
// sus hijos hoja ("2.1", "2.2"...) comparten el mismo level.
model CostAccount {
  id        String  @id @default(cuid())
  clienteId String
  code      String // "2", "2.1", "3.5"
  name      String
  level     Int // 2, 3, 4, 5 (grupo contable, no profundidad)
  parentId  String?
  order     Int     @default(0)

  isProject Boolean @default(false) // true = costo directo de obra (nivel 2)
  isSystem  Boolean @default(false) // true = NO capturable, se calcula (Nómina Op/Admin)

  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  parent      CostAccount?  @relation("AccountTree", fields: [parentId], references: [id])
  children    CostAccount[] @relation("AccountTree")
  costs       Cost[]
  budgetItems BudgetItem[]

  @@unique([clienteId, code])
  @@index([clienteId, level, active])
}

model Cost {
  id           String    @id @default(cuid())
  projectId    String? // null = gasto fijo de empresa (niveles 3/4/5); requerido si la cuenta es isProject
  accountId    String
  budgetItemId String? // opcional: costo sin clasificar a partida
  elementId    String? // opcional: costo asociado a un elemento (estructurista)
  supplierName String? // texto libre por ahora (no hay módulo de proveedores)
  date         DateTime
  description  String
  invoiceRef   String? // folio/UUID de factura
  amount       Decimal   @db.Decimal(14, 2)
  paidAt       DateTime? // null = comprometido; con fecha = pagado
  source       String    @default("MANUAL") // MANUAL | EXCEL_IMPORT
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  project    Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  account    CostAccount @relation(fields: [accountId], references: [id])
  budgetItem BudgetItem? @relation(fields: [budgetItemId], references: [id])
  element    Element?    @relation(fields: [elementId], references: [id])

  @@index([projectId, date])
  @@index([accountId, date])
}

// Nómina real pagada por mes/tipo — regla #12: MO aplicada (Σ TimeEntry) vs
// nómina real (este modelo). El diferencial es la ociosidad, a nivel empresa.
model PayrollPeriod {
  id        String   @id @default(cuid())
  clienteId String
  year      Int
  month     Int
  type      String // OPERATIVA | ADMINISTRATIVA
  amount    Decimal  @db.Decimal(14, 2) // nómina REAL pagada
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clienteId, year, month, type])
}

model Employee {
  id         String    @id @default(cuid())
  clienteId  String
  code       String?
  name       String
  role       String? // albañil, oficial, cabo, ingeniero
  hourlyCost Decimal   @db.Decimal(10, 2) // costo/hora INTEGRADO (con carga social)
  active     Boolean   @default(true)
  isLeader   Boolean   @default(false)
  crewId     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  crew        Crew?               @relation("CrewMembers", fields: [crewId], references: [id])
  leads       Crew?               @relation("CrewLeader")
  timeEntries TimeEntry[]
  assignments ProjectAssignment[]

  @@index([clienteId, active])
}

model TimeEntry {
  id           String   @id @default(cuid())
  projectId    String
  employeeId   String
  budgetItemId String?
  elementId    String? // opcional: horas asociadas a un elemento (estructurista)
  date         DateTime @db.Date
  hours        Decimal  @db.Decimal(6, 2)
  hourlyCost   Decimal  @db.Decimal(10, 2) // SNAPSHOT de Employee.hourlyCost
  amount       Decimal  @db.Decimal(14, 2) // hours * hourlyCost
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime? // soft delete — nunca se pierde el historial de horas

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee   Employee    @relation(fields: [employeeId], references: [id])
  budgetItem BudgetItem? @relation(fields: [budgetItemId], references: [id])
  element    Element?    @relation(fields: [elementId], references: [id])

  @@unique([projectId, employeeId, elementId, date])
  @@index([projectId, date])
  @@index([employeeId, date])
}

model Estimate {
  id           String         @id @default(cuid())
  projectId    String
  number       Int
  periodStart  DateTime       @db.Date
  periodEnd    DateTime       @db.Date
  progressPct  Decimal        @db.Decimal(5, 2) // % avance acumulado
  grossAmount  Decimal        @db.Decimal(14, 2) // avance del periodo (INGRESO)
  retention    Decimal        @default(0) @db.Decimal(14, 2)
  advanceAmort Decimal        @default(0) @db.Decimal(14, 2) // amortización de anticipo
  netAmount    Decimal        @db.Decimal(14, 2) // gross - retention - advanceAmort
  status       EstimateStatus @default(BORRADOR)
  authorizedAt DateTime?
  paidAt       DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, number])
  @@index([projectId, status])
}

model Usuario {
  id               String    @id @default(cuid())
  nombre           String
  apellido         String
  email            String    @unique
  password         String?
  microsoftId      String?
  avatar           String?
  activo           Boolean   @default(true)
  rolId            String
  rol              Rol       @relation(fields: [rolId], references: [id])
  clienteId        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  ultimoAcceso     DateTime?
  emailVerificado  Boolean   @default(false)
  primerAcceso     Boolean   @default(true)
  tipoUsuario      String    @default("comprador")
}

model Rol {
  id           String       @id @default(cuid())
  nombre       String
  descripcion  String?
  esAdmin      Boolean      @default(false)
  esSupervisor Boolean      @default(false)
  clienteId    String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  permisos RolPermiso[]
  usuarios Usuario[]
}

model RolPermiso {
  id       String  @id @default(cuid())
  rolId    String
  rol      Rol     @relation(fields: [rolId], references: [id])
  modulo   String
  ver      Boolean @default(false)
  crear    Boolean @default(false)
  editar   Boolean @default(false)
  eliminar Boolean @default(false)

  @@unique([rolId, modulo])
}

model CatalogoValor {
  id        String   @id @default(cuid())
  tipo      String
  codigo    String
  nombre    String
  simbolo   String?
  activo    Boolean  @default(true)
  orden     Int      @default(0)
  clienteId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tipo, codigo, clienteId])
}

model Crew {
  id        String    @id @default(cuid())
  clienteId String
  name      String
  leaderId  String    @unique
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  leader  Employee   @relation("CrewLeader", fields: [leaderId], references: [id])
  members Employee[] @relation("CrewMembers")

  @@index([clienteId, active])
}

model ProjectAssignment {
  id         String    @id @default(cuid())
  projectId  String
  employeeId String
  assignedAt DateTime  @default(now())
  removedAt  DateTime?

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([projectId, employeeId])
}

model ElementStage {
  id        String  @id @default(cuid())
  clienteId String
  code      String // HABILITADO, FABRICADO, EN_SITIO, MONTADO
  name      String
  weightPct Decimal @db.Decimal(5, 2) // los pesos deben sumar 100 por tenant
  order     Int

  progress ElementProgress[]

  @@unique([clienteId, code])
}

model ElementType {
  id          String  @id @default(cuid())
  clienteId   String
  code        String // "IPR-12x40", "PL-12MM"
  name        String // "Viga IPR 12x40"
  family      String // CatalogoValor TIPO_ELEMENTO (Viga/Placa/Columna/...)
  description String?

  material String? // A36, A572 Gr.50, A992
  section  String? // IPR, IPS, HSS, OR, PTR

  // Dimensiones nominales (opcionales según familia)
  lengthM     Decimal? @db.Decimal(10, 3)
  widthMm     Decimal? @db.Decimal(10, 2)
  heightMm    Decimal? @db.Decimal(10, 2)
  thicknessMm Decimal? @db.Decimal(10, 2) // clave en placas
  diameterMm  Decimal? @db.Decimal(10, 2) // clave en barras

  // Peso — base de todo el cálculo de avance
  weightUnit  String  @default("KG_M") // KG_M | KG_PZA
  weightValue Decimal @db.Decimal(12, 3)

  // Costo
  priceUnit      String  @default("KG") // KG | PZA | M
  estimatedPrice Decimal @db.Decimal(14, 2)

  paintAreaM2 Decimal? @db.Decimal(10, 4) // m² a pintar (por m o por pza)
  notes       String?

  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  elements Element[]

  @@unique([clienteId, code])
  @@index([clienteId, family, active])
}

model Element {
  id            String  @id @default(cuid())
  projectId     String
  budgetItemId  String? // apunta a la PARTIDA (nodo padre de BudgetItem, parentId=null), nunca a una línea (regla #14)
  elementTypeId String?
  code          String // "V-101"
  name          String
  type          String // catálogo TIPO_ELEMENTO (snapshot de ElementType.family)
  material      String? // snapshot de ElementType.material
  description   String?

  length Decimal? @db.Decimal(10, 3)
  width  Decimal? @db.Decimal(10, 3)
  height Decimal? @db.Decimal(10, 3)
  weight Decimal  @db.Decimal(12, 3) // kg UNITARIO

  qty         Int     @default(1)
  unitCost    Decimal @db.Decimal(14, 2)
  totalCost   Decimal @db.Decimal(14, 2) // unitCost × qty
  progressPct Decimal @default(0) @db.Decimal(5, 2) // DERIVADO, no capturable

  installedAt DateTime? // se marca cuando la etapa MONTADO llega a qty completa

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetItem  BudgetItem?       @relation(fields: [budgetItemId], references: [id])
  elementType ElementType?      @relation(fields: [elementTypeId], references: [id])
  progress    ElementProgress[]
  timeEntries TimeEntry[]
  costs       Cost[]

  @@unique([projectId, code])
  @@index([projectId, budgetItemId])
}

model ElementProgress {
  id        String   @id @default(cuid())
  elementId String
  stageId   String
  qtyDone   Int      @default(0)
  updatedAt DateTime @updatedAt

  element Element      @relation(fields: [elementId], references: [id], onDelete: Cascade)
  stage   ElementStage @relation(fields: [stageId], references: [id])

  @@unique([elementId, stageId])
}
